{
  "id": "paddle-ocr",
  "name": "Paddle OCR",
  "version": "0.4.0",
  "description": "基于 PaddleOCR 的本地离线 OCR 插件",
  "author": "AIO Hub Team",
  "icon": "🔎",
  "tags": ["OCR", "PaddleOCR", "本地模型"],
  "host": {
    "appVersion": ">=0.6.4",
    "apiVersion": 2
  },
  "type": "sidecar",
  "sidecar": {
    "resident": true,
    "executable": {
      "win32-x64": "target/x86_64-pc-windows-msvc/debug/aiohub-paddle-ocr.exe"
    },
    "args": [],
    "startupMethod": "recognizeBatch",
    "startupParams": {}
  },
  "methods": [
    {
      "name": "recognizeBatch",
      "displayName": "批量 OCR 识别",
      "description": "使用本地 PaddleOCR 模型批量识别图片块中的文字",
      "parameters": [
        {
          "name": "images",
          "type": "array",
          "required": true,
          "description": "待识别图片块列表"
        },
        {
          "name": "options",
          "type": "object",
          "required": false,
          "description": "模型、语言和识别参数"
        }
      ],
      "returnType": "Promise<PaddleOcrBatchResult>"
    }
  ],
  "contributions": [
    {
      "type": "ocr-engine",
      "id": "ppocr-v5-mobile",
      "name": "Paddle OCR",
      "description": "基于 PP-OCRv5 Mobile 的本地离线 OCR 引擎",
      "method": "recognizeBatch",
      "modelProfiles": [
        {
          "id": "ppocr-v5-mobile-general",
          "name": "PP-OCRv5 Mobile 通用",
          "language": "general"
        },
        {
          "id": "ppocr-v5-mobile-en",
          "name": "PP-OCRv5 Mobile 英文",
          "language": "en"
        },
        {
          "id": "ppocr-v5-mobile-ko",
          "name": "PP-OCRv5 Mobile 韩文",
          "language": "ko"
        },
        {
          "id": "ppocr-v5-mobile-latin",
          "name": "PP-OCRv5 Mobile 拉丁文字",
          "language": "latin"
        },
        {
          "id": "ppocr-v5-mobile-arabic",
          "name": "PP-OCRv5 Mobile 阿拉伯文字",
          "language": "arabic"
        },
        {
          "id": "ppocr-v5-mobile-cyrillic",
          "name": "PP-OCRv5 Mobile 西里尔文字",
          "language": "cyrillic"
        },
        {
          "id": "ppocr-v5-mobile-el",
          "name": "PP-OCRv5 Mobile 希腊文",
          "language": "el"
        },
        {
          "id": "ppocr-v5-mobile-devanagari",
          "name": "PP-OCRv5 Mobile 天城文",
          "language": "devanagari"
        },
        {
          "id": "ppocr-v5-mobile-ta",
          "name": "PP-OCRv5 Mobile 泰米尔文",
          "language": "ta"
        },
        {
          "id": "ppocr-v5-mobile-te",
          "name": "PP-OCRv5 Mobile 泰卢固文",
          "language": "te"
        },
        {
          "id": "ppocr-v5-mobile-th",
          "name": "PP-OCRv5 Mobile 泰文",
          "language": "th"
        }
      ],
      "defaultModelProfile": "ppocr-v5-mobile-general",
      "capabilities": {
        "batch": true,
        "confidence": true,
        "preferredImageMimeTypes": ["image/png", "image/jpeg", "image/webp"]
      }
    }
  ],
  "ui": {
    "displayName": "Paddle OCR",
    "component": "PaddleOcr.vue",
    "icon": "🔎"
  }
}

